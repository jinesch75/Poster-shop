# ================================================
# Linework Studio — environment variables
# Copy this file to .env.local for local development
# ================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Linework Studio"

# --- Database (Session 2+) ---
# Railway will inject DATABASE_URL in production
DATABASE_URL="postgresql://user:password@localhost:5432/linework_studio"

# --- Auth.js (Session 4+) ---
AUTH_SECRET=""
AUTH_EMAIL_SERVER=""
AUTH_EMAIL_FROM="hello@linework.studio"

# --- Stripe (Session 4+) ---
# Test mode keys for dev (pk_test_… / sk_test_…), live keys only in prod.
# Grab keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
# Generated by the Stripe CLI or the webhook endpoint settings page.
# For local dev:  stripe listen --forward-to localhost:3000/api/webhooks/stripe
# For Railway:    dashboard → Developers → Webhooks → add endpoint
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Email (Resend — Session 4+) ---
RESEND_API_KEY=""

# --- Admin ---
ADMIN_EMAIL="brosiusjacques@gmail.com"
# Password for the /admin login in Session 2 (replaced by magic links in Session 4)
ADMIN_PASSWORD="change-me-in-production"

# --- Storage (Session 2+) ---
# In production Railway mounts a volume at /data/linework and we write there.
# Locally we default to ./uploads. Override here only if you need a custom path.
# STORAGE_ROOT="./uploads"

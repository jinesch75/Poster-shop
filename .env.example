# ================================================
# Gridline Cities — environment variables
# Copy this file to .env.local for local development
# ================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Gridline Cities"

# --- Database (Session 2+) ---
# Railway will inject DATABASE_URL in production
DATABASE_URL="postgresql://user:password@localhost:5432/line drawings_studio"

# --- Auth.js (Session 4+) ---
AUTH_SECRET=""
AUTH_EMAIL_SERVER=""
AUTH_EMAIL_FROM="hello@gridlinecities.com"

# --- Stripe (Session 4+) ---
# Test mode keys for dev (pk_test_… / sk_test_…), live keys only in prod.
# Grab keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
# Generated by the Stripe CLI or the webhook endpoint settings page.
# For local dev:  stripe listen --forward-to localhost:3000/api/webhooks/stripe
# For Railway:    dashboard → Developers → Webhooks → add endpoint
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Email (Brevo — Session 5+) ---
# v3 API key from Brevo → Settings → SMTP & API. Create a fresh key rather
# than re-using the dashboard key so it can be rotated independently.
BREVO_API_KEY=""
# Verified sender. Single-sender verification is fine pre-domain; once we
# own a domain, switch to a domain-verified sender for better deliverability.
BREVO_SENDER_EMAIL="brosiusjacques@gmail.com"
BREVO_SENDER_NAME="Gridline Cities"
# Numeric list ID (Brevo → Contacts → Lists). The "Gridline Cities" list
# was created on 2026-04-23 with id 3.
BREVO_NEWSLETTER_LIST_ID="3"

# --- Admin ---
ADMIN_EMAIL="brosiusjacques@gmail.com"
# Password for the /admin login in Session 2 (replaced by magic links in Session 4)
ADMIN_PASSWORD="change-me-in-production"

# --- Storage (Session 2+) ---
# In production Railway mounts a volume at /data/line drawings and we write there.
# Locally we default to ./uploads. Override here only if you need a custom path.
# STORAGE_ROOT="./uploads"
